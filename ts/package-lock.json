{
  "name": "minilab-ts-workspace",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "minilab-ts-workspace",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@minilab/contracts": {
      "resolved": "packages/minilab-contracts",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.4.5",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.4.5.tgz",
      "integrity": "sha512-vcI4UpRgg81oIRUFwR0WSIHKt11nJ7SAVlYNIu+QpqeyXP+gpQJy/Z4+F0aGxSE4MqwjyXvW/TzgkLAx2AGHwQ==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/minilab-contracts": {
      "name": "@minilab/contracts",
      "version": "0.0.0",
      "devDependencies": {
        "typescript": "~5.4.0"
      }
    }
  }
}
